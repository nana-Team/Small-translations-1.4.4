	DuskChakramProj.DisplayName: "{$Items.DuskChakram.DisplayName}"
	DuskShadow.DisplayName: Сумрачная тень
	BloodstainedKunaiProj.DisplayName: "{$Items.BloodstainedKunai.DisplayName}"
	BambooStickProj.DisplayName: "{$Items.BambooStick.DisplayName}"
	ImpalingJavelinProj.DisplayName: "{$Items.ImpalingJavelin.DisplayName}"
