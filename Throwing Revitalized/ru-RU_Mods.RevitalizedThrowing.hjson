	HydroMesanglyonReleased.DisplayName: "{$Items.HydroMesanglyon.DisplayName}"
	HydroMesanglyonSweetSpot.DisplayName: Критическое попадание Гидромезанглиона
	BrambleShurikenProj.DisplayName: "{$Items.BrambleShuriken.DisplayName}"
	BlazingFalaricaProj.DisplayName: "{$Items.BlazingFalarica.DisplayName}"
	BlazingExplosion.DisplayName: Пылающий взрыв
	ChromapurgeProj.DisplayName: "{$Items.Chromapurge.DisplayName}"
	ChromapurgeSplit.DisplayName: Хромакинжал
	ObsidianKnifeProj.DisplayName: "{$Items.ObsidianKnife.DisplayName}"
	ShimmerKnifeProj.DisplayName: "{$Items.ShimmerKnife.DisplayName}"
	VoidBombProj.DisplayName: "{$Items.VoidBomb.DisplayName}"
	VoidBombShockwave.DisplayName: Взрывная волна пустотной бомбы
	VoidExplosion.DisplayName: Пустотный взрыв
	JunglesVengeanceProj.DisplayName: "{$Items.JunglesVengeance.DisplayName}"
	JunglesVengeanceHeal.DisplayName: Лечение «Возмездия джунглей»
	CoralFlame.DisplayName: Глубоководный удар
}

Prefixes: {
	SerratedPrefix.DisplayName: Пилообразный
	VindictivePrefix.DisplayName: Мстительный
	BarbaricPrefix.DisplayName: Варварский
	MaleficentPrefix.DisplayName: Зловредный
	RestlessPrefix.DisplayName: Неугомонный
	TraitorousPrefix.DisplayName: Вероломный
}

Buffs: {
	AssassinCooldown: {
		DisplayName: Перезарядка убийственной атаки
		Description: Вы не можете использовать «убийственное» оружие
	}

	Sparking: {
		DisplayName: Искрящийся
		Description: Раскалённые искры вылетают из вашего тела
	}

	Impaled: {
		DisplayName: Пронзённый
		Description: Защита снижена на 10 ед.
	}

	Blazing: {
		DisplayName: Пылающий
		Description: Обжигающе!
	}

	BloodyBoost: {
		Description:
			'''
			Метательный урон увеличен на {0}%
			Скорость регенерации увеличена
			'''
		DisplayName: Кровавое усиление
	}

	VoidRend: {
		DisplayName: Пустотный разрыв
		Description: Вас разрывает на части
	}

	JunglesWrath: {
		Description: Вы пронзены «Возмездием джунглей»
		DisplayName: Ярость джунглей
	}
}

SetBonusNinja:
	'''
	{$CommonItemTooltip.PercentAssassinCooldownDecrease}
	{$CommonItemTooltip.PercentThrowingVelocityIncrease@1}
	'''

Configs: {
	ReclasserConfig: {
		DisplayName: Конфигурация классовости оружия

		formerThrowing: {
			Label: Расходуемое оружие стрелка
			Tooltip: Всё стрелковое оружие, раньше принадлежащее метателю, снова станет таковым.
		}

		Headers: {
			itemClasses: Типы оружия
			individualItems: Конкретные предметы
		}

		paperAirplanes: {
			Label: Бумажные самолётики
			Tooltip: Оба вида самолётиков будут наносить метательный урон.
		}

		boomerangs: {
			Label: Бумеранги
			Tooltip: Всё оружие ближнего боя, возвращающееся после броска, будет наносить метательный урон. Мод не будет добавлять новых бумерангов.
		}

		yoyos: {
			Label: Йо-йо
			Tooltip:
				'''
				Технически йо-йо тоже метается, да?
				Все йо-йо будут наносить метательный урон. Мод не будет добавлять новых йо-йо.
				'''
		}

		flyingKnife: {
			Label: Летающий нож
			Tooltip:
				'''
				Что-то типа бумеранга, но не совсем.
				Летающий нож будет наносить метательный урон.
				'''
		}

		scourgeOfTheCorruptor: {
			Label: "{$ItemName.ScourgeoftheCorruptor}"
			Tooltip: "{$ItemName.ScourgeoftheCorruptor} будет наносить метательный урон."
		}

		vampireKnives: {
			Label: Вампирские ножи
			Tooltip: Вампирские ножи будут наносить метательный урон, потому что они похожи на метательные ножи.
		}

		magicDagger: {
			Label: Магический кинжал
			Tooltip: Магический кинжал будет наносить метательный урон и не будет требовать ману.
		}

		toxicFlask: {
			Label: Токсичный флакон
			Tooltip: Токсичный флакон будет наносить метательный урон и не будет требовать ману.
		}

		shadowflameKnife: {
			Label: Нож теневого пламени
			Tooltip: Нож теневого пламени будет наносить метательный урон.
		}

		daybreak: {
			Label: "{$ItemName.Daybreak}"
			Tooltip: "{$ItemName.Daybreak} будет наносить метательный урон."
		}
	}
}
