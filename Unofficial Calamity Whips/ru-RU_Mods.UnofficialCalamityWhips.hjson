Configs: {
	UnofficialCalamityWhipsConfig: {
		DisplayName: Unofficial Calamity Whips Config
		Headers.Config: Config Header

		WhipDamageModifier: {
			Label: Whip Damage Modifer
			Tooltip: Modifies the damage of every whip in this mod by the chosen number. Use this to buff or nerf the mod as you see fit
		}

		AddArmorStats: {
			Label: Add Whip Stats to Calamity Armors
			Tooltip: Adds extra whip stats to some calamity armors while enabled, to make whips more viable
		}

		AllowTagStacking: {
			Label: Enable Tag Debuff Stacking
			Tooltip: Allows whips in this mod to stack their tag effects. If set to false, all previous tag effects will be removed on applying a new one
		}

		CatalystDisclaimer: {
			Label: Catalyst Disclaimer
			Tooltip: Disable this to remove the disclaimer advertising the Catalyst Mod
		}
	}
}

