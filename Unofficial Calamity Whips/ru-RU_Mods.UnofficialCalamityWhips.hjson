Items: {
	WulfrumChain: {
	DisplayName: Вульфрумовая цепь
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Хрупкая конструкция, но вариантов не то чтобы много
			'''
	}

	StaticScourge: {
		DisplayName: Электростатический бич
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Быстрый, но короткий хлыст, электризующий врагов
			Атаки миньонов по наэлектризованным врагам выпускают наносящие урон искры и снимают заряд
			'''
	}

	FungalFlailItem: {
		DisplayName: Грибной кистень
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Атаки миньонов будут создавать самонаводящиеся грибы, исцеляющие вас
			4 ед. урона от метки призывателя
			'Несъедобен'
			'''
	}

	SkySplitterItem: {
		DisplayName: Рассекатель небес
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Атаки хлыстом восстанавливают время полёта
			5 ед. урона от метки призывателя
			'Лёгкий как пёрышко'
			'''
	}

	CongeledDuoWhip: {
		DisplayName: Загустевший двойной хлыст
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Left click to shoot two slimy whips in the same directions
			Right click to charge up shoot two slimy whips in opposite directions
			10 ед. урона от метки призывателя
			'''
	}

	SulphuricScourge: {
		DisplayName: Sulphuric Scourge
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Your minions will release toxic clouds into the air
			'''
	}

	DaedalusWhipItem: {
		DisplayName: Daedalus Whip
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Summons floating snowballs on tag which split into ice shards
			11 ед. урона от метки призывателя
			'Imbued with the power of Cryogen'
			'''
	}

	PrismBreak: {
		DisplayName: Призмолом
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Your minions will release a volley of crystal shrapnel
			-Community Designed Item-
			Design by 'reldandle'
			'''
	}

	BrimstoneLash: {
		DisplayName: Lash of Languish
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Inflicts Brimstone Flame
			Your minions will release a brimstone explosion on a hit
			'Languish in the flames of Gehenna'
			'''
	}

	StellarWindItem: {
		DisplayName: Stellar Wind
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Inflicts Astral Infection.
			Your minions will call down astral stars on a hit
			'''
	}

	SandstoneReigns: {
		DisplayName: Forgotten Predator
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Your minions will summon a vicious sand shark to tag team
			'Let them know what you have seen today'
			'''
	}

	RightousDawn: {
		DisplayName: Star Scrapper
		Tooltip:
			'''
			Something doesn't feel right....
			Maybe you shouldn't use this...
			'''
	}

	ResonateStriker: {
		DisplayName: Resonant Striker
		Tooltip: Infuses you with pure resonance on each hit, increasing your movement and melee speed
	}

	RighteousDawnTwo: {
		DisplayName: Righteous Dawn
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Inflicts Holy Flames
			If you are nearby your target, your minions will heal and imbue you with greater resistance
			'A true king leads their troops into battle'
			'''
	}

	UnrelentingTorment: {
		DisplayName: Неумолимая тоска
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Releases a torment of ghastly claws
			Your minions will call disembodied claws from beyond
			'''
	}

	SlimySling: {
		DisplayName: Sticky Fingers
		Tooltip: Increases whip range by 8%
	}

	GelatinousGlove: {
		DisplayName: Worn Grip
		Tooltip:
			'''
			12% increased melee and whip speed
			Enables auto swing for melee weapons and whips
			Increases whip range by 15%
			Whips slow nonboss enemies
			Grants a burst of speed after hitting with a whip
			'''
	}

	CrystalLodestone: {
		DisplayName: Forbidden Remains
		Tooltip: Your whips release exploding boulders
	}

	FossilizedAmber: {
		DisplayName: Fossilized Amber
		Tooltip: Gain 8 defense after hitting with a whip
	}

	CrystalOfResilience: {
		DisplayName: Crystalized Lodestone
		Tooltip:
			'''
			Your whips release exploding boulders
			Gain 8 defense after hitting with a whip
			20% increased mining speed, 5% damage reduction, and +10 defense while underground or in the underworld
			'''
	}

	Centauri: {
		DisplayName: Proxima Centauri
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Can and will hurl planets
			50 ед. урона от метки призывателя
			'Nearest, but far beyond...'
			'''
	}

	FlinxFurMitten: {
		DisplayName: Flinx Fur Mittens
		Tooltip:
			'''
			12% increased melee and whip speed
			Enables auto swing for melee weapons and whips
			Whips slow enemies that are not immune to confusion
			Increases whip range by 8%
			'''
	}

	RingOfAlacrity: {
		DisplayName: Ring of Alacrity
		Tooltip: Gain 10% movement speed after hitting with a whip
	}

	SuspiciousLeafExtract: {
		DisplayName: Suspicious Leaf Extract
		Tooltip: Spawns a circle of orbiting leaves after hitting with a whip
	}

	BoulderItem: {
		DisplayName: Stone Rubble
		Tooltip: Your whips will shoot out boulders
	}

	BlossomsBlessingItem: {
		DisplayName: Благословение цветения
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Gives you The Blossom's Blessing on hit 
			25% chance to shoot a spore
			30 ед. урона от метки призывателя
			'''
	}

	CoralCrusherItem: {
		DisplayName: Коралловый крушитель
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Your minions summon coral fragments
			6 ед. урона от метки призывателя
			'''
	}

	DevourersMaw: {
		DisplayName: Devourer's Maw
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			Will infuse you with the Devourer's Hunger on hit, granting power the more you attack.
			Inflicts Godslayer Inferno
			-Community Designed Item-
			Design by 'MothEggs, Paige, and KumaTerra'
			'''
	}

	SirensSerenityItem: {
		DisplayName: Siren's Serenity
		Tooltip:
			'''
			{$CommonItemTooltip.Whips}
			The companionship between the Leviathan and Anahita inspires you and your minions
			Your minions will occasionally drop orbs that will heal and grant a buff when picked up
			18 ед. урона от метки призывателя
			-Community Designed Item-
			Design by 'CharlieTheFatCat'
			'''
	}

	DivineHeadpat: {
		DisplayName: Divine Headpat
		Tooltip: Pat pat
	}

	BuffOrb: {
		DisplayName: Buff Orb
		Tooltip: ""
	}

	HealingOrb: {
		DisplayName: Healing Orb
		Tooltip: ""
	}

	TrueStarScraper: {
		DisplayName: True Star Scraper
		Tooltip: He was feeling a bit grumpy, but he's better now.
	}
}

