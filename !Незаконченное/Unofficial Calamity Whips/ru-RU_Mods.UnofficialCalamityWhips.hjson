		Description: Урон вражеских миньонов по вам увеличен
	}

	CoralCrusherDebuff: {
		DisplayName: Кальцификация
		Description: На вашем теле растут увесиистые кораллы
	}

	FungalFlailDebuff: {
		DisplayName: Грибной паразит
		Description: Теперь вы — пища для противника
	}

	SkySplitterDebuff: {
		DisplayName: Небесная метка
		Description: Урон вражеских миньонов по вам увеличен
	}

	StaticTagDebuff: {
		DisplayName: Наэлектризованность
		Description: В вас столько статческого электричетсва, что видны искры!
	}
