	}

	DevourersHunger: {
		DisplayName: Голод Пожирателя
		Description: Ваши защита и урон возрастают с каждым ударом Пасти Пожирателя
	}

	HealingMelody: {
		DisplayName: Исцеляющая мелодия
		Description: Защита и регенерация жизни увеличены
	}

	BitterCold: {
		DisplayName: Обморожение
		Description: Выс трудом ощущаете ваши конечности
	}

	BrimstoneTagDebuff: {
		DisplayName: Серное перенасыщение
		Description: Переполняющая вас сера вот-вот взорвётся
	}

	DaedalusWhipDebuff: {
		DisplayName: Сверхзаморозка
		Description: Ваше тело столь холодно, что превращает влагу воздуха в снежинки
	}

	PrismTagDebuff: {
		DisplayName: Быстрая кристаллизация
		Description: Из вашего тела растут призмы
	}

	SandstoneTagDebuff: {
		DisplayName: Акулий аромат
		Description: Вы — лучшая приманка для акул
	}

	SirensSerenityDebuff: {
		DisplayName: Песнь наяды
		Description: Ваши слёзы превращаются в силу ваших врагов
	}

	StarScraperDebuff: {
		DisplayName: Метка звёздной пыли
		Description: Урон вражеских миньонов по вам увеличен
	}

	StellarWindDebuff: {
		DisplayName: Метеоритный магнит
		Description: Все падающие звёзды ваши!
	}

	SulphuricTagDebuff: {
		DisplayName: Радиосверхактивность
		Description: В вашем теле так много радиации, что она конденсируется в облака
	}

	BlossomsBlessingDebuff: {
		DisplayName: Метка цветущей природы
		Description: Урон вражеских миньонов по вам увеличен
	}

	CentauriDebuff: {
		DisplayName: Метка бесконечного космоса
		Description: Урон вражеских миньонов по вам увеличен
	}

	DevourerTagDebuff: {
		DisplayName: Метка Пожирателя
		Description: Урон вражеских миньонов по вам увеличен
	}

	ResonateTagDebuff: {
		DisplayName: Антирезонанс
		Description: Урон вражеских миньонов по вам увеличен
	}

	RighteousTagDebuff: {
		DisplayName: Раскаяние
