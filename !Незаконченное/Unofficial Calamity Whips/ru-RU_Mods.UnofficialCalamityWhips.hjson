		DisplayName: Невесомость
		Description: Время полёта увеличено
	}

	StarlightTouch: {
		DisplayName: Прикосновение звёздного света
		Description: Скорость регенерации здоровья увеличена, получено 20 ед. защиты
	}

	RighteousBlessing: {
		DisplayName: Праведное благословение
		Description: Скорость регенерации здоровья увеличена, получено 30 ед. защиты
	}

	StonesEndurance: {
		DisplayName: Контролируемое оцепенение
		Description: Сопротивление урону увеличено на 10%
